# ─── Development Caddyfile (no TLS) ──────────────────────────────────────────
{
    auto_https off
    local_certs
}

:80 {
    handle /api/* {
        reverse_proxy backend:3001
    }

    handle /health {
        reverse_proxy backend:3001
    }

    handle /uploads/* {
        root * /srv
        file_server
    }

    handle {
        reverse_proxy admin:3000
    }
}
