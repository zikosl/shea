# ─── Admin Frontend Development Image ────────────────────────────────────────
# Runs Next.js in dev mode with hot module replacement.
# Source code is mounted as a volume at runtime.
#
# Usage: referenced by docker-compose.dev.yml
FROM node:22-alpine
RUN apk add --no-cache libc6-compat wget
WORKDIR /app
# Install ALL deps
COPY package.json yarn.lock ./
RUN yarn install --frozen-lockfile
# Copy Next config so Next.js can initialise
COPY next.config.ts ./
# Copy public dir if it exists
COPY public* ./public/
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV NODE_ENV=development
CMD ["yarn", "dev"]
